@page "/admin/login"
@layout AuthLayout
@rendermode InteractiveServer

<PageTitle>Admin Login</PageTitle>

<section class="login-page">
    <div class="brand-panel">
        <img class="login-hero-image"
             src="images/login-hero.png"
             alt="Viva Bambolina bridal atelier branding" />
    </div>

    <div class="login-card" aria-label="Admin login form">
        <div class="login-card-header">
            <p class="eyebrow">Secure sign in</p>
            <h2>Welcome Back</h2>
            <p>Use your credentials to continue.</p>
        </div>

        <form method="post" action="@LoginAction">
            <AntiforgeryToken />
            <div class="form-stack">
                <label>
                    Email
                    <input class="form-control" name="Email" type="email" autocomplete="username" value="admin@vivabambolina.com" placeholder="admin@vivabambolina.com" required />
                </label>

                <label>
                    Password
                    <input class="form-control" name="Password" type="password" autocomplete="current-password" placeholder="Enter password" minlength="8" required />
                </label>

                <div class="login-row">
                    <label class="check-row">
                        <input name="RememberDevice" type="checkbox" value="true" checked />
                        <span>Remember this device</span>
                    </label>

                    <a href="mailto:admin@vivabambolina.com">Need access?</a>
                </div>

                @if (!string.IsNullOrWhiteSpace(statusMessage))
                {
                    <div class="login-status" role="status">@statusMessage</div>
                }

                <button class="btn btn-primary login-button" type="submit">
                    Sign In
                </button>
            </div>
        </form>
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "error")]
    private string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "loggedOut")]
    private string? LoggedOut { get; set; }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    private string? ReturnUrl { get; set; }

    private string LoginAction => string.IsNullOrWhiteSpace(ReturnUrl)
        ? "/api/auth/session-login"
        : $"/api/auth/session-login?returnUrl={Uri.EscapeDataString(ReturnUrl)}";

    private string? statusMessage => Error switch
    {
        "invalid" => "Those credentials did not match an active admin account.",
        "oauth" => "OAuth completed, but the account is not linked to an active admin user.",
        _ when LoggedOut == "1" => "You have been signed out.",
        _ => null
    };
}
