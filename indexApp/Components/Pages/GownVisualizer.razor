@page "/visualizer"
@page "/ai-visualizer"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.Security.Claims
@using indexApp.Features.AiVisualizer.Entities
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject FileStorageService FileStorageService
@inject MeasurementService MeasurementService
@inject VisualizerService VisualizerService

<PageTitle>AI Gown Visualizer</PageTitle>

<div class="visualizer-page">
    <header class="visualizer-topbar">
        <a class="wordmark" href="/">Viva Bambolina</a>
        <a class="history-link" href="/visualizer/history">Preview history</a>
    </header>

    <main class="visualizer-shell">
        <aside class="stepper" aria-label="Visualizer steps">
            @foreach (var step in steps)
            {
                <button type="button" class="@(activeStep == step.Number ? "active" : null)" @onclick="() => activeStep = step.Number">
                    <span>@step.Number</span>
                    <strong>@step.Title</strong>
                    <small>@step.Description</small>
                </button>
            }
        </aside>

        <section class="configuration-panel" aria-label="Visualizer configuration">
            <div class="panel-heading">
                <p class="eyebrow">Guided visualizer</p>
                <h1>@SelectedStyle?.Name</h1>
                <strong>@((SelectedStyle?.BasePrice ?? 0).ToString("C0"))</strong>
            </div>

            @if (isLoading)
            {
                <p class="surface-message">Loading visualizer catalog...</p>
            }
            else
            {
                <div class="field-block">
                    <label for="style">1. Style &amp; Design</label>
                    <select id="style" class="form-control" @bind="selectedStyleId">
                        @foreach (var style in styles)
                        {
                            <option value="@style.Id">@style.Name</option>
                        }
                    </select>
                    <small>@SelectedStyle?.Description</small>
                </div>

                <div class="field-block">
                    <label for="fabric">2. Fabric</label>
                    <select id="fabric" class="form-control" @bind="selectedFabricId">
                        @foreach (var fabric in fabrics)
                        {
                            <option value="@fabric.Id">@fabric.Name</option>
                        }
                    </select>

                    <div class="swatches" aria-label="Fabric colors">
                        @foreach (var color in SelectedFabric?.Colors ?? [])
                        {
                            <button type="button"
                                    class="@(selectedColorId == color.Id ? "selected" : null)"
                                    style="background:@color.HexCode"
                                    title="@color.ColorName"
                                    @onclick="() => selectedColorId = color.Id"></button>
                        }
                    </div>
                </div>

                <EditForm Model="measurements">
                    <DataAnnotationsValidator />
                    <div class="field-block">
                        <label>3. Measurements <small>(inches)</small></label>
                        <div class="measurement-grid">
                            <label>Height <InputNumber class="form-control" @bind-Value="measurements.Height" /></label>
                            <label>Bust <InputNumber class="form-control" @bind-Value="measurements.Bust" /></label>
                            <label>Waist <InputNumber class="form-control" @bind-Value="measurements.Waist" /></label>
                            <label>Hips <InputNumber class="form-control" @bind-Value="measurements.Hips" /></label>
                            <label>Shoulder <InputNumber class="form-control" @bind-Value="measurements.ShoulderWidth" /></label>
                            <label>Dress length <InputNumber class="form-control" @bind-Value="measurements.DressLength" /></label>
                            <label>Sleeve length <InputNumber class="form-control" @bind-Value="measurements.SleeveLength" /></label>
                            <label>Wrist <InputNumber class="form-control" @bind-Value="measurements.Wrist" /></label>
                        </div>
                        <ValidationSummary />
                    </div>
                </EditForm>

                <div class="upload-card">
                    <InputFile OnChange="OnPhotoSelected" accept="image/jpeg,image/png,image/webp" />
                    <div>
                        <strong>@(photoFile?.Name ?? "Upload front-facing full-body photo")</strong>
                        <small>JPG, PNG, or WebP up to 10MB.</small>
                    </div>
                </div>

                @if (messages.Count > 0)
                {
                    <div class="alert-list" role="status">
                        @foreach (var message in messages)
                        {
                            <p>@message</p>
                        }
                    </div>
                }

                <button type="button" class="generate-button" disabled="@isGenerating" @onclick="GeneratePreviewAsync">
                    @(isGenerating ? "Generating AI preview..." : "Generate AI Preview")
                </button>
            }
        </section>

        <section class="preview-panel" aria-label="Visualizer preview">
            <div class="preview-header">
                <div>
                    <p class="eyebrow">Basic Preview</p>
                    <h2>Mannequin approximation</h2>
                    <p>Updates instantly without an AI call.</p>
                </div>
            </div>

            <div class="mannequin-stage" style="@PreviewCss">
                <div class="mannequin">
                    <div class="head"></div>
                    <div class="shoulders"></div>
                    <div class="bodice"></div>
                    <div class="sleeve left"></div>
                    <div class="sleeve right"></div>
                    <div class="skirt"></div>
                </div>
            </div>

            <div class="ai-output">
                <div>
                    <p class="eyebrow">AI Generated Preview</p>
                    <h2>@(latestPreviewUrl is null ? "No AI preview yet" : "Preview ready")</h2>
                    <p>AI previews are for visualization purposes only. Final gown fit, fabric behavior, color, and appearance may vary.</p>
                </div>

                @if (latestPreviewUrl is not null)
                {
                    <img src="@latestPreviewUrl" alt="Generated AI gown preview" />
                    <a class="download-button"
                       href="@($"/api/visualizer/request/{latestPreviewRequestId}/download-preview")"
                       download="viva-bambolina-ai-preview.png"
                       aria-label="Download image"
                       title="Download image">
                        <img class="download-icon" src="/images/icons/download-logo.jpg" alt="" />
                    </a>
                }
            </div>
        </section>
    </main>
</div>

@code {
    private readonly Step[] steps =
    [
        new(1, "Style & Design", "Choose gown silhouette"),
        new(2, "Fabric & Color", "Pick fabric and swatch"),
        new(3, "Measurements", "Enter fitting values"),
        new(4, "Upload Photo", "Required reference photo"),
        new(5, "AI Preview", "Generate result")
    ];

    private IReadOnlyList<DressStyleDto> styles = [];
    private IReadOnlyList<FabricDto> fabrics = [];
    private readonly MeasurementDto measurements = new();
    private readonly List<string> messages = [];
    private Guid selectedStyleId;
    private Guid selectedFabricId;
    private Guid selectedColorId;
    private IBrowserFile? photoFile;
    private string? latestPreviewUrl;
    private Guid? latestPreviewRequestId;
    private int activeStep = 1;
    private bool isLoading = true;
    private bool isGenerating;

    private DressStyleDto? SelectedStyle => styles.FirstOrDefault(style => style.Id == selectedStyleId);

    private FabricDto? SelectedFabric => fabrics.FirstOrDefault(fabric => fabric.Id == selectedFabricId);

    private FabricColorDto? SelectedColor => SelectedFabric?.Colors.FirstOrDefault(color => color.Id == selectedColorId);

    private string PreviewCss
    {
        get
        {
            var scale = MeasurementService.GetScale(measurements);
            return $"--gown-color:{SelectedColor?.HexCode ?? "#f1cfc3"};--height:{1 + scale.Height};--bust:{1 + scale.Bust};--waist:{1 + scale.Waist};--hips:{1 + scale.Hips};--shoulder:{1 + scale.Shoulder};--dress-length:{1 + scale.DressLength};--sleeve:{scale.SleeveLength};--wrist:{1 + scale.Wrist};";
        }
    }

    protected override async Task OnInitializedAsync()
    {
        styles = await VisualizerService.GetStylesAsync();
        fabrics = await VisualizerService.GetFabricsAsync();
        selectedStyleId = styles.FirstOrDefault()?.Id ?? Guid.Empty;
        selectedFabricId = fabrics.FirstOrDefault()?.Id ?? Guid.Empty;
        selectedColorId = fabrics.FirstOrDefault()?.Colors.FirstOrDefault()?.Id ?? Guid.Empty;
        isLoading = false;
    }

    private void OnPhotoSelected(InputFileChangeEventArgs args)
    {
        var candidate = args.File;
        activeStep = 4;
        messages.Clear();

        if (candidate.ContentType is not ("image/jpeg" or "image/png" or "image/webp"))
        {
            photoFile = null;
            messages.Add("Please upload a JPG, PNG, or WebP image.");
            return;
        }

        if (candidate.Size > 10 * 1024 * 1024)
        {
            photoFile = null;
            messages.Add("The selected image is too large. Maximum size is 10MB.");
            return;
        }

        photoFile = candidate;
    }

    private async Task GeneratePreviewAsync()
    {
        messages.Clear();
        latestPreviewUrl = null;
        latestPreviewRequestId = null;
        activeStep = 5;

        var errors = MeasurementService.Validate(measurements);
        if (errors.Count > 0)
        {
            messages.AddRange(errors);
            return;
        }

        if (selectedStyleId == Guid.Empty || selectedFabricId == Guid.Empty || selectedColorId == Guid.Empty)
        {
            messages.Add("Choose a style, fabric, and color before generating.");
            return;
        }

        if (photoFile is null)
        {
            messages.Add("Upload a front-facing full-body photo so the AI preview can visualize the gown on you.");
            return;
        }

        isGenerating = true;

        try
        {
            var userId = await GetUserIdAsync();
            var uploadedPhotoUrl = await FileStorageService.SaveUploadAsync(photoFile, userId);
            var request = await VisualizerService.CreateRequestAsync(
                userId,
                new CreateVisualizerRequestDto
                {
                    DressStyleId = selectedStyleId,
                    FabricId = selectedFabricId,
                    FabricColorId = selectedColorId,
                    Measurement = measurements
                },
                uploadedPhotoUrl);

            var result = await VisualizerService.GenerateAiPreviewAsync(
                userId,
                new GenerateAiPreviewRequest(request.Id, "standard", "1024x1536"));

            if (result.ImageUrl is null)
            {
                messages.Add(result.ErrorMessage ?? "AI preview generation failed.");
                return;
            }

            latestPreviewUrl = result.ImageUrl;
            latestPreviewRequestId = result.VisualizerRequestId;
            messages.Add("AI preview generated and saved to your history.");
        }
        catch (Exception ex)
        {
            messages.Add($"AI preview generation failed: {ex.Message}");
        }
        finally
        {
            isGenerating = false;
        }
    }

    private async Task<string> GetUserIdAsync()
    {
        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        return state.User.FindFirstValue(ClaimTypes.NameIdentifier)
            ?? throw new InvalidOperationException("You must be signed in to use the visualizer.");
    }

    private sealed record Step(int Number, string Title, string Description);
}
