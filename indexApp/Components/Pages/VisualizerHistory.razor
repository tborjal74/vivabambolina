@page "/visualizer/history"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.Security.Claims
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject VisualizerService VisualizerService

<PageTitle>Preview History</PageTitle>

<main class="history-page">
    <header>
        <a href="/visualizer">Back to visualizer</a>
        <h1>Preview History</h1>
        <p>Your generated previews are private to your account.</p>
    </header>

    @if (isLoading)
    {
        <p class="empty-state">Loading history...</p>
    }
    else if (items.Count == 0)
    {
        <p class="empty-state">No generated previews yet.</p>
    }
    else
    {
        <section class="history-grid" aria-label="Generated previews">
            @foreach (var item in items)
            {
                <article class="history-card">
                    <img src="@item.ImageUrl" alt="Generated gown preview" />
                    <div>
                        <h2>@item.StyleName</h2>
                        <p>@item.FabricName · @item.ColorName</p>
                        <small>@item.CreatedAt.ToLocalTime().ToString("g")</small>
                        <div class="history-actions">
                            <a href="@($"/api/visualizer/request/{item.RequestId}/download-preview")"
                               class="icon-download-button"
                               download="viva-bambolina-ai-preview.png"
                               aria-label="Download image"
                               title="Download image">
                                <img src="/images/icons/download-logo.jpg" alt="" />
                            </a>
                            <button type="button"
                                    class="delete-button"
                                    disabled="@deletingRequestIds.Contains(item.RequestId)"
                                    @onclick="() => DeletePreviewAsync(item.RequestId)">
                                @(deletingRequestIds.Contains(item.RequestId) ? "Deleting..." : "Delete")
                            </button>
                        </div>
                    </div>
                </article>
            }
        </section>
    }
</main>

@code {
    private IReadOnlyList<PreviewHistoryItemDto> items = [];
    private readonly HashSet<Guid> deletingRequestIds = [];
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var userId = state.User.FindFirstValue(ClaimTypes.NameIdentifier)
            ?? throw new InvalidOperationException("You must be signed in to view history.");

        items = await VisualizerService.GetHistoryAsync(userId);
        isLoading = false;
    }

    private async Task DeletePreviewAsync(Guid requestId)
    {
        deletingRequestIds.Add(requestId);
        try
        {
            var state = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = state.User.FindFirstValue(ClaimTypes.NameIdentifier)
                ?? throw new InvalidOperationException("You must be signed in to remove a preview.");

            if (await VisualizerService.DeletePrivateMediaAsync(userId, requestId))
            {
                items = items.Where(item => item.RequestId != requestId).ToList();
            }
        }
        finally
        {
            deletingRequestIds.Remove(requestId);
        }
    }
}
