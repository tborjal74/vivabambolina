@page "/"
@layout AuthLayout
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Security.Claims
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject FileStorageService FileStorageService
@inject VisualizerService VisualizerService

<PageTitle>Viva Bambolina Home</PageTitle>

<div class="home-shell">
    <header class="store-nav" aria-label="Store header">
        <div aria-hidden="true"></div>
        <a class="wordmark" href="">Viva Bambolina</a>

        <div class="nav-actions" aria-label="Account actions">
            <AuthorizeView>
                <Authorized Context="authState">
                    <div class="admin-session">
                        <span>@GetEmail(authState.User)</span>
                        <form method="post" action="/api/auth/logout">
                            <button type="submit" title="Sign out">Logout</button>
                        </form>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <a class="account-link" href="admin/login" title="Account">Sign in</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </header>

    <main class="product-studio">
        <aside class="product-column" aria-label="Gown setup">
            <div class="product-card">
                <div class="gown-art" aria-hidden="true">
                    <div class="dress-bodice"></div>
                    <div class="dress-skirt"></div>
                </div>
            </div>

            <section class="step-list" aria-label="Visualizer steps">
                @foreach (var step in steps)
                {
                    <button type="button" class="@GetStepClass(step.Number)">
                        <span>@step.Number</span>
                        <strong>@step.Title</strong>
                        <small>@step.Description</small>
                    </button>
                }
            </section>
        </aside>

        <section class="config-panel" aria-label="AI visualizer settings">
            <div class="product-title">
                <p class="eyebrow">AI Visualizer</p>
                <h1>@selectedStyle</h1>
            </div>

            <div class="settings-card">
                <div class="settings-heading">
                    <span>✧</span>
                    <div>
                        <h2>See how it looks on you</h2>
                        <p>Choose the gown details, add measurements, and preview the look.</p>
                    </div>
                </div>

                <div class="field-block">
                    <label for="style">1. Style &amp; Design</label>
                    <select id="style" class="form-control" @bind="selectedStyle">
                        @foreach (var style in catalogStyles)
                        {
                            <option value="@style.Name">@style.Name</option>
                        }
                    </select>
                </div>

                <div class="field-block">
                    <label for="fabric">2. Fabric &amp; Color</label>
                    <select id="fabric" class="form-control" @bind="selectedFabric" @bind:after="OnFabricChanged">
                        @foreach (var fabric in catalogFabrics)
                        {
                            <option value="@fabric.Name">@fabric.Name</option>
                        }
                    </select>

                    <div class="swatches" aria-label="Gown color">
                        @foreach (var color in SelectedFabric?.Colors ?? [])
                        {
                            <button type="button"
                                    class="@(selectedColor == color.ColorName ? "selected" : null)"
                                    style="background:@color.HexCode"
                                    title="@color.ColorName"
                                    @onclick="() => selectedColor = color.ColorName"></button>
                        }
                    </div>
                </div>

                <div class="field-block">
                    <label>3. Measurements <small>(inches)</small></label>
                    <div class="measurement-grid">
                        <label>Height <input class="form-control" type="number" min="36" max="96" step=".1" @bind="measurementValues.Height" /></label>
                        <label>Bust <input class="form-control" type="number" min="20" max="80" step=".1" @bind="measurementValues.Bust" /></label>
                        <label>Waist <input class="form-control" type="number" min="18" max="70" step=".1" @bind="measurementValues.Waist" /></label>
                        <label>Hips <input class="form-control" type="number" min="20" max="85" step=".1" @bind="measurementValues.Hips" /></label>
                        <label>Shoulder Width <input class="form-control" type="number" min="8" max="32" step=".1" @bind="measurementValues.ShoulderWidth" /></label>
                        <label>Dress Length <input class="form-control" type="number" min="20" max="90" step=".1" @bind="measurementValues.DressLength" /></label>
                        <label>Sleeve Length <input class="form-control" type="number" min="0" max="40" step=".1" @bind="measurementValues.SleeveLength" /></label>
                    </div>
                </div>

                <div class="upload-card">
                    <div class="upload-row">
                    <label class="upload-picker" for="photo-upload">
                        <InputFile class="file-input"
                                   id="photo-upload"
                                   @key="photoInputKey"
                                   OnChange="OnPhotoSelected"
                                   accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
                        <span>☁</span>
                        <strong title="@uploadedPhotoFileName">@(uploadedPhotoFileName ?? "Upload Self Photo")</strong>
                        <small>JPG, PNG, or WEBP up to 10MB</small>
                    </label>
                    <div class="photo-thumb">
                    @if (uploadedPhotoDataUrl is null)
                    {
                        <div class="mini-photo" aria-hidden="true"></div>
                    }
                    else
                    {
                        <img class="mini-photo uploaded-mini-photo" src="@uploadedPhotoDataUrl" alt="Selected photo preview" />
                        <button type="button" class="remove-photo-button" title="Remove photo" aria-label="Remove Uploaded Self Photo" @onclick="RemoveUploadedPhoto">
                            &times;
                        </button>
                    }
                    </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(photoUploadError))
                    {
                        <p class="validation-message" role="alert">@photoUploadError</p>
                    }
                </div>
                <button type="button" class="generate-button" disabled="@isGenerating" @onclick="GeneratePreviewAsync">
                    @(isGenerating ? "Generating AI Preview..." : "Generate AI Preview")
                </button>

                @if (!string.IsNullOrWhiteSpace(generationMessage))
                {
                    <p class="generation-message @(generationSucceeded ? "success" : "error")" role="status">@generationMessage</p>
                }
            </div>
        </section>

        <section class="preview-panel" aria-label="AI generated preview">
            <div class="preview-header">
                <div>
                    <p class="eyebrow">AI Generated Preview</p>
                    <h2>Customer gown visualization</h2>
                    <p>This preview is for visualization only.</p>
                </div>
                @if (latestPreviewRequestId is Guid previewRequestId)
                {
                    <a class="outline-button"
                       href="@($"/api/visualizer/request/{previewRequestId}/download-preview")"
                       download="viva-bambolina-ai-preview.png"
                       aria-label="Download image"
                       title="Download image">
                        <img class="download-icon" src="/images/icons/download-logo.jpg" alt="" />
                    </a>
                }
            </div>

            <div class="comparison">
                <figure>
                    <span>Your Photo</span>
                    @if (uploadedPhotoDataUrl is null)
                    {
                        <img class="frame-placeholder" src="images/placeholders/your-photo-placeholder.png" alt="Your photo placeholder" />
                    }
                    else
                    {
                        <img class="uploaded-photo-preview" src="@uploadedPhotoDataUrl" alt="Uploaded Self Photo" />
                    }
                </figure>
                <div class="compare-arrow" aria-hidden="true">→</div>
                <figure>
                    <span>AI Preview</span>
                    <img class="frame-placeholder @(latestPreviewUrl is null ? null : "generated-preview")"
                         src="@(latestPreviewUrl ?? "images/placeholders/ai-preview-placeholder.png")"
                         alt="@(latestPreviewUrl is null ? "AI preview placeholder" : "Generated AI gown preview")" />
                </figure>
            </div>

            <div class="preview-note">
                <span>ⓘ</span>
                <p>The AI preview is generated for visualization purposes only. Final gown fit, fabric behavior, and appearance may vary.</p>
            </div>

            <div class="checkout-row">
                <div class="quantity-control" aria-label="Quantity">
                    <button type="button" @onclick="DecreaseQuantity">−</button>
                    <span>@quantity</span>
                    <button type="button" @onclick="IncreaseQuantity">+</button>
                </div>
            </div>

            <aside class="selection-card" aria-label="Your selections">
                <div>
                    <h3>Your Selections</h3>
                    <button type="button">Edit</button>
                </div>
                <ul>
                    <li>Style: @selectedStyle</li>
                    <li>Fabric: @selectedFabric</li>
                    <li>Color: @selectedColor</li>
                    <li>Measurements: 7 values entered</li>
                    <li>Photo: @(uploadedPhotoFileName is null ? "Not uploaded" : uploadedPhotoFileName)</li>
                </ul>
            </aside>
        </section>
    </main>
</div>

@code {
    private int quantity = 1;
    private string selectedStyle = "Embellished A-Line Gown";
    private string selectedFabric = "Sequin Tulle";
    private string selectedColor = "Blush Pink";
    private string? uploadedPhotoDataUrl;
    private string? uploadedPhotoFileName;
    private string? photoUploadError;
    private string? latestPreviewUrl;
    private Guid? latestPreviewRequestId;
    private string? generationMessage;
    private bool generationSucceeded;
    private IBrowserFile? selectedPhotoFile;
    private IReadOnlyList<DressStyleDto> catalogStyles = [];
    private IReadOnlyList<FabricDto> catalogFabrics = [];
    private readonly MeasurementDto measurementValues = new();
    private bool isGenerating;
    private int photoInputKey;

    private const long MaxPhotoBytes = 10 * 1024 * 1024;

    private static readonly HashSet<string> AllowedPhotoExtensions = new(StringComparer.OrdinalIgnoreCase)
    {
        ".jpg",
        ".jpeg",
        ".png",
        ".webp"
    };

    private static readonly HashSet<string> AllowedPhotoContentTypes = new(StringComparer.OrdinalIgnoreCase)
    {
        "image/jpeg",
        "image/png",
        "image/webp"
    };

    private readonly Step[] steps =
    [
        new(1, "Style & Design", "Select your gown style"),
        new(2, "Fabric & Color", "Choose fabric and color"),
        new(3, "Measurements", "Enter your measurements"),
        new(4, "Upload Photo", "Upload your photo"),
        new(5, "AI Preview", "Generate your preview")
    ];

    private FabricDto? SelectedFabric => catalogFabrics.FirstOrDefault(fabric => fabric.Name == selectedFabric);

    private string GetStepClass(int stepNumber) => stepNumber == 1 ? "active" : string.Empty;

    private static string GetEmail(System.Security.Claims.ClaimsPrincipal user)
    {
        return user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
            ?? user.Identity?.Name
            ?? "Admin";
    }

    private void DecreaseQuantity() => quantity = Math.Max(1, quantity - 1);

    private void IncreaseQuantity() => quantity++;

    protected override async Task OnInitializedAsync()
    {
        catalogStyles = await VisualizerService.GetStylesAsync();
        catalogFabrics = await VisualizerService.GetFabricsAsync();
        selectedStyle = catalogStyles.FirstOrDefault(style => style.Name == selectedStyle)?.Name
            ?? catalogStyles.FirstOrDefault()?.Name
            ?? selectedStyle;
        selectedFabric = catalogFabrics.FirstOrDefault(fabric => fabric.Name == selectedFabric)?.Name
            ?? catalogFabrics.FirstOrDefault()?.Name
            ?? selectedFabric;
        OnFabricChanged();
    }

    private void OnFabricChanged()
    {
        selectedColor = SelectedFabric?.Colors.FirstOrDefault(color => color.ColorName == selectedColor)?.ColorName
            ?? SelectedFabric?.Colors.FirstOrDefault()?.ColorName
            ?? selectedColor;
    }

    private async Task OnPhotoSelected(InputFileChangeEventArgs args)
    {
        var photo = args.File;
        var extension = Path.GetExtension(photo.Name);

        uploadedPhotoDataUrl = null;
        uploadedPhotoFileName = null;
        photoUploadError = null;
        selectedPhotoFile = null;

        if (!AllowedPhotoExtensions.Contains(extension) || !AllowedPhotoContentTypes.Contains(photo.ContentType))
        {
            photoUploadError = "Please upload a JPG, PNG, or WEBP image.";
            return;
        }

        if (photo.Size > MaxPhotoBytes)
        {
            photoUploadError = "Please upload an image that is 10MB or smaller.";
            return;
        }

        await using var stream = photo.OpenReadStream(MaxPhotoBytes);
        using var memory = new MemoryStream();
        await stream.CopyToAsync(memory);

        uploadedPhotoFileName = photo.Name;
        uploadedPhotoDataUrl = $"data:{photo.ContentType};base64,{Convert.ToBase64String(memory.ToArray())}";
        selectedPhotoFile = photo;
    }

    private void RemoveUploadedPhoto()
    {
        uploadedPhotoDataUrl = null;
        uploadedPhotoFileName = null;
        photoUploadError = null;
        selectedPhotoFile = null;
        photoInputKey++;
    }

    private async Task GeneratePreviewAsync()
    {
        generationMessage = null;
        generationSucceeded = false;

        if (selectedPhotoFile is null)
        {
            photoUploadError = "Upload a front-facing full-body photo before generating your AI preview.";
            generationMessage = "A photo is required so the AI preview can visualize the gown on you.";
            return;
        }

        var style = catalogStyles.FirstOrDefault(item => item.Name == selectedStyle);
        var fabric = catalogFabrics.FirstOrDefault(item => item.Name == selectedFabric);
        var color = fabric?.Colors.FirstOrDefault(item => item.ColorName == selectedColor)
            ?? fabric?.Colors.FirstOrDefault();

        if (style is null || fabric is null || color is null)
        {
            generationMessage = "The selected style, fabric, or color is unavailable.";
            return;
        }

        isGenerating = true;
        try
        {
            var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authenticationState.User.FindFirstValue(ClaimTypes.NameIdentifier);
            if (string.IsNullOrWhiteSpace(userId))
            {
                generationMessage = "Please sign in before generating a preview.";
                return;
            }

            var uploadedPhotoUrl = await FileStorageService.SaveUploadAsync(selectedPhotoFile, userId);

            var request = await VisualizerService.CreateRequestAsync(
                userId,
                new CreateVisualizerRequestDto
                {
                    DressStyleId = style.Id,
                    FabricId = fabric.Id,
                    FabricColorId = color.Id,
                    Measurement = measurementValues
                },
                uploadedPhotoUrl);

            var result = await VisualizerService.GenerateAiPreviewAsync(
                userId,
                new GenerateAiPreviewRequest(request.Id, "medium", "1024x1536"));

            if (string.IsNullOrWhiteSpace(result.ImageUrl))
            {
                generationMessage = result.ErrorMessage ?? "AI preview generation failed. Please try again.";
                return;
            }

            latestPreviewUrl = result.ImageUrl;
            latestPreviewRequestId = result.VisualizerRequestId;
            generationMessage = "AI preview generated successfully.";
            generationSucceeded = true;
        }
        catch (Exception ex)
        {
            generationMessage = $"AI preview generation failed: {ex.Message}";
        }
        finally
        {
            isGenerating = false;
        }
    }

    private sealed record Step(int Number, string Title, string Description);

}
