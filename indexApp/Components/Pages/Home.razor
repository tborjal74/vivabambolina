@page "/"
@layout AuthLayout
@rendermode InteractiveServer
@attribute [Authorize]
@using System.Security.Claims
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject FileStorageService FileStorageService
@inject VisualizerService VisualizerService

<PageTitle>Viva Bambolina Home</PageTitle>

<div class="home-shell">
    <header class="store-nav" aria-label="Store header">
        <div aria-hidden="true"></div>
        <a class="wordmark" href="">Viva Bambolina</a>

        <div class="nav-actions" aria-label="Account actions">
            <AuthorizeView>
                <Authorized Context="authState">
                    <div class="admin-session">
                        <span>@GetEmail(authState.User)</span>
                        <form method="post" action="/api/auth/logout">
                            <AntiforgeryToken />
                            <button type="submit" title="Sign out">Logout</button>
                        </form>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <a class="account-link" href="admin/login" title="Account">Sign in</a>
                </NotAuthorized>
            </AuthorizeView>
        </div>
    </header>

    <main class="product-studio">
        <section class="config-panel" aria-label="AI visualizer settings">
            <div class="settings-card">
                <aside class="design-panel" aria-label="Style and design">
                    <div class="product-title">
                        <p class="eyebrow">Dress Builder</p>
                        <h1>@(string.IsNullOrWhiteSpace(selectedDressTemplate) ? "Your Custom Gown" : selectedDressTemplate)</h1>
                    </div>

                    <div class="product-card">
                        <div class="gown-art" aria-hidden="true">
                            <div class="dress-bodice"></div>
                            <div class="dress-skirt"></div>
                        </div>
                    </div>

                    <div class="settings-heading">
                        <span>✧</span>
                        <div>
                            <h2>See how it looks on you</h2>
                            <p>Choose the gown details, add measurements, and preview the look.</p>
                        </div>
                    </div>

                    <div class="field-block">
                        <label for="dress-template">1. Dress Template</label>
                        <select id="dress-template" class="form-control @(string.IsNullOrWhiteSpace(selectedDressTemplate) ? "placeholder-control" : null)" @bind="selectedDressTemplate">
                            <option value="" disabled>Select dress template...</option>
                            @foreach (var template in DressTemplates)
                            {
                                <option value="@template">@template</option>
                            }
                        </select>
                    </div>

                    <div class="field-block">
                        <label for="neckline">2. Neckline Shape</label>
                        <select id="neckline" class="form-control @(string.IsNullOrWhiteSpace(measurementValues.NecklineShape) ? "placeholder-control" : null)" @bind="measurementValues.NecklineShape">
                            <option value="" disabled>Select neckline shape...</option>
                            @foreach (var shape in MeasurementService.NecklineShapes)
                            {
                                <option value="@shape">@shape</option>
                            }
                        </select>
                    </div>

                    <div class="field-block">
                        <label for="sleeve-shape">3. Sleeve Shape</label>
                        <select id="sleeve-shape" class="form-control @(string.IsNullOrWhiteSpace(measurementValues.SleeveShape) ? "placeholder-control" : null)" @bind="measurementValues.SleeveShape">
                            <option value="" disabled>Select sleeve shape...</option>
                            @foreach (var shape in MeasurementService.SleeveShapes)
                            {
                                <option value="@shape">@shape</option>
                            }
                        </select>
                    </div>

                    <div class="field-block">
                        <label for="bodice-design">4. Upper Body / Bodice Design</label>
                        <select id="bodice-design" class="form-control @(string.IsNullOrWhiteSpace(selectedBodiceDesign) ? "placeholder-control" : null)" @bind="selectedBodiceDesign">
                            <option value="" disabled>Select bodice design...</option>
                            @foreach (var design in BodiceDesigns)
                            {
                                <option value="@design">@design</option>
                            }
                        </select>
                    </div>

                    <div class="field-block">
                        <label for="waist-shape">5. Waist Shape</label>
                        <select id="waist-shape" class="form-control @(string.IsNullOrWhiteSpace(selectedWaistShape) ? "placeholder-control" : null)" @bind="selectedWaistShape">
                            <option value="" disabled>Select waist shape...</option>
                            @foreach (var shape in WaistShapes)
                            {
                                <option value="@shape">@shape</option>
                            }
                        </select>
                    </div>

                    <div class="field-block">
                        <label for="skirt-design">6. Skirt Design</label>
                        <select id="skirt-design" class="form-control @(string.IsNullOrWhiteSpace(measurementValues.SkirtShape) ? "placeholder-control" : null)" @bind="measurementValues.SkirtShape">
                            <option value="" disabled>Select skirt design...</option>
                            @foreach (var design in MeasurementService.SkirtShapes)
                            {
                                <option value="@design">@design</option>
                            }
                        </select>
                    </div>

                    <div class="field-block material-field">
                        <label>7. Fabric Type</label>
                        <div class="material-grid" aria-label="Select fabric type">
                            @foreach (var fabric in FabricTypes)
                            {
                                <button type="button"
                                        class="material-option @(selectedFabricType == fabric.Name ? "selected" : null)"
                                        aria-pressed="@(selectedFabricType == fabric.Name)"
                                        @onclick="() => selectedFabricType = fabric.Name">
                                    <span class="material-sample fabric-@fabric.SampleClass" aria-hidden="true"></span>
                                    <span>@fabric.Name</span>
                                </button>
                            }
                        </div>
                    </div>

                    <div class="field-block material-field">
                        <label>8. Fabric Texture / Pattern</label>
                        <div class="material-grid" aria-label="Select fabric texture or pattern">
                            @foreach (var pattern in FabricPatterns)
                            {
                                <button type="button"
                                        class="material-option @(selectedFabricPattern == pattern.Name ? "selected" : null)"
                                        aria-pressed="@(selectedFabricPattern == pattern.Name)"
                                        @onclick="() => selectedFabricPattern = pattern.Name">
                                    <span class="material-sample pattern-@pattern.SampleClass" aria-hidden="true"></span>
                                    <span>@pattern.Name</span>
                                </button>
                            }
                        </div>
                    </div>

                    <div class="field-block color-field">
                        <label>9. Color</label>
                        <div class="honeycomb-picker" aria-label="Select gown color">
                            @foreach (var row in ColorPaletteRows)
                            {
                                <div class="honeycomb-row">
                                    @foreach (var color in row)
                                    {
                                        <button type="button"
                                                class="hex-color @(pickedColorHex == color.HexCode ? "selected" : null)"
                                                style="background-color:@color.HexCode"
                                                aria-label="Choose @color.Name, @color.HexCode"
                                                aria-pressed="@(pickedColorHex == color.HexCode)"
                                                title="@($"{color.Name} ({color.HexCode})")"
                                                @onclick="() => SelectPaletteColor(color)"></button>
                                    }
                                </div>
                            }
                        </div>
                        <div class="color-picker-row" aria-live="polite">
                            <span class="picked-color" style="background-color:@pickedColorHex" aria-hidden="true"></span>
                            <div class="color-match">
                                @if (SelectedPaletteColor is not null)
                                {
                                    <strong>@SelectedPaletteColor.Name</strong>
                                    <small>@SelectedPaletteColor.HexCode</small>
                                }
                                else
                                {
                                    <strong>Select a shade</strong>
                                    <small>Choose a color from the palette.</small>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="field-block">
                        <label for="accessories">10. Accessories</label>
                        <select id="accessories" class="form-control @(string.IsNullOrWhiteSpace(selectedAccessories) ? "placeholder-control" : null)" @bind="selectedAccessories">
                            <option value="" disabled>Select accessories...</option>
                            @foreach (var accessory in Accessories)
                            {
                                <option value="@accessory">@accessory</option>
                            }
                        </select>
                    </div>

                    <div class="field-block">
                        <label for="back-closure">11. Back Closure</label>
                        <select id="back-closure" class="form-control @(string.IsNullOrWhiteSpace(selectedBackClosure) ? "placeholder-control" : null)" @bind="selectedBackClosure">
                            <option value="" disabled>Select back closure...</option>
                            @foreach (var closure in BackClosures)
                            {
                                <option value="@closure">@closure</option>
                            }
                        </select>
                    </div>
                </aside>

                <div class="field-block measurements-panel">
                    <label>12. Measurements <small>(centimeters)</small></label>
                    <div class="measurement-grid">
                        <label>Size
                            <select class="form-control" @bind="measurementValues.Size">
                                <option value="">Select size...</option>
                                @foreach (var size in MeasurementService.Sizes)
                                {
                                    <option value="@size">@size</option>
                                }
                            </select>
                        </label>
                        <label>Chest <input class="form-control" type="number" placeholder="0" min="50" max="205" step=".1" @bind="measurementValues.Chest" /></label>
                        <label>Waist <input class="form-control" type="number" placeholder="0" min="45" max="180" step=".1" @bind="measurementValues.Waist" /></label>
                        <label>Shoulder to Shoulder <input class="form-control" type="number" placeholder="0" min="20" max="82" step=".1" @bind="measurementValues.ShoulderToShoulder" /></label>
                        <label>Shoulder to Waist Seam <input class="form-control" type="number" placeholder="0" min="20" max="80" step=".1" @bind="measurementValues.ShoulderToWaistSeam" /></label>
                        <label>Shoulder to Hem <input class="form-control" type="number" placeholder="0" min="50" max="230" step=".1" @bind="measurementValues.ShoulderToHem" /></label>
                        <label>Sleeve Length <input class="form-control" type="number" placeholder="0" min="0" max="102" step=".1" @bind="measurementValues.SleeveLength" /></label>
                        <label>Bicep <input class="form-control" type="number" placeholder="0" min="15" max="70" step=".1" @bind="measurementValues.Bicep" /></label>
                        <label>End of Sleeve <input class="form-control" type="number" placeholder="0" min="10" max="41" step=".1" @bind="measurementValues.EndOfSleeve" /></label>
                        <label>Shoulder to Side Neck <input class="form-control" type="number" placeholder="0" min="5" max="35" step=".1" @bind="measurementValues.ShoulderToSideNeck" /></label>
                        <label>Shoulder to Neck Opening <input class="form-control" type="number" placeholder="0" min="5" max="60" step=".1" @bind="measurementValues.ShoulderToNeckOpening" /></label>
                        <label>Mock Neck Height <input class="form-control" type="number" placeholder="0" min="0" max="25" step=".1" @bind="measurementValues.MockNeckHeight" /></label>
                        <label>Mock Neck Circumference <input class="form-control" type="number" placeholder="0" min="0" max="80" step=".1" @bind="measurementValues.MockNeckCircumference" /></label>
                        <label>Underarm to Side Waist Seam <input class="form-control" type="number" placeholder="0" min="5" max="60" step=".1" @bind="measurementValues.UnderarmToSideWaistSeam" /></label>
                        <label>Center Neck to Waist Point <input class="form-control" type="number" placeholder="0" min="15" max="90" step=".1" @bind="measurementValues.CenterNeckToWaistPoint" /></label>
                        <label>Cuff Height <input class="form-control" type="number" placeholder="0" min="0" max="30" step=".1" @bind="measurementValues.CuffHeight" /></label>
                        <label>Horsehair Edge Hem
                            <select class="form-control @(measurementValues.HasHorsehairEdgeHem is null ? "placeholder-control" : null)" @bind="HorsehairEdgeHemSelection">
                                <option value="" disabled>Y/N...</option>
                                <option value="no">No</option>
                                <option value="yes">Yes</option>
                            </select>
                        </label>
                        <label>Built-in Puffy
                            <select class="form-control @(measurementValues.HasBuiltInPuffy is null ? "placeholder-control" : null)" @bind="BuiltInPuffySelection">
                                <option value="" disabled>Y/N...</option>
                                <option value="no">No</option>
                                <option value="yes">Yes</option>
                            </select>
                        </label>
                    </div>
                </div>

                <section class="right-panel" aria-label="Photo and selection details">
                <div class="upload-card">
                    <h2>Upload Photo</h2>
                    <div class="upload-row">
                    <label class="upload-picker" for="photo-upload">
                        <InputFile class="file-input"
                                   id="photo-upload"
                                   @key="photoInputKey"
                                   OnChange="OnPhotoSelected"
                                   accept=".jpg,.jpeg,.png,.webp,image/jpeg,image/png,image/webp" />
                        <span>☁</span>
                        <strong title="@uploadedPhotoFileName">@(uploadedPhotoFileName ?? "Upload Self Photo")</strong>
                        <small>JPG, PNG, or WEBP up to 10MB</small>
                    </label>
                    <div class="photo-thumb">
                    @if (uploadedPhotoDataUrl is null)
                    {
                        <img class="mini-photo empty-upload-icon" src="/images/icons/upload-photo-logo.jpg" alt="" aria-hidden="true" />
                    }
                    else
                    {
                        <img class="mini-photo uploaded-mini-photo" src="@uploadedPhotoDataUrl" alt="Selected photo preview" />
                        <button type="button" class="remove-photo-button" title="Remove photo" aria-label="Remove Uploaded Self Photo" @onclick="RemoveUploadedPhoto">
                            &times;
                        </button>
                    }
                    </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(photoUploadError))
                    {
                        <p class="validation-message" role="alert">@photoUploadError</p>
                    }
                </div>
                <aside class="selection-card" aria-label="Your selections">
                    <h3>Your Selection Summary</h3>
                    <ul>
                        <li>Template: @(string.IsNullOrWhiteSpace(selectedDressTemplate) ? "Not selected" : selectedDressTemplate)</li>
                        <li>Neckline: @(string.IsNullOrWhiteSpace(measurementValues.NecklineShape) ? "Not selected" : measurementValues.NecklineShape)</li>
                        <li>Sleeve: @(string.IsNullOrWhiteSpace(measurementValues.SleeveShape) ? "Not selected" : measurementValues.SleeveShape)</li>
                        <li>Bodice: @(string.IsNullOrWhiteSpace(selectedBodiceDesign) ? "Not selected" : selectedBodiceDesign)</li>
                        <li>Waist: @(string.IsNullOrWhiteSpace(selectedWaistShape) ? "Not selected" : selectedWaistShape)</li>
                        <li>Skirt: @(string.IsNullOrWhiteSpace(measurementValues.SkirtShape) ? "Not selected" : measurementValues.SkirtShape)</li>
                        <li>Fabric: @(string.IsNullOrWhiteSpace(selectedFabricType) ? "Not selected" : selectedFabricType)</li>
                        <li>Texture: @(string.IsNullOrWhiteSpace(selectedFabricPattern) ? "Not selected" : selectedFabricPattern)</li>
                        <li>Color: @(SelectedPaletteColor is null ? "Not selected" : $"{SelectedPaletteColor.Name} ({SelectedPaletteColor.HexCode})")</li>
                        <li>Accessories: @(string.IsNullOrWhiteSpace(selectedAccessories) ? "Not selected" : selectedAccessories)</li>
                        <li>Closure: @(string.IsNullOrWhiteSpace(selectedBackClosure) ? "Not selected" : selectedBackClosure)</li>
                        <li>Measurements: @(string.IsNullOrWhiteSpace(measurementValues.Size) ? "Not entered" : $"{measurementValues.Size} size entered")</li>
                        <li>Photo: @(uploadedPhotoFileName is null ? "Not uploaded" : uploadedPhotoFileName)</li>
                    </ul>
                </aside>
                </section>
            </div>
        </section>

        <section class="preview-panel" aria-label="AI generated preview">
            <div class="preview-header">
                <div>
                    <p class="eyebrow">AI Generated Preview</p>
                    <h2>Customer gown visualization</h2>
                    <p>This preview is for visualization only.</p>
                </div>
                @if (latestPreviewRequestId is Guid previewRequestId)
                {
                    <a class="outline-button"
                       href="@GetPreviewDownloadUrl(previewRequestId)"
                       download="viva-bambolina-ai-preview.png"
                       aria-label="Download image"
                       title="Download image">
                        <img class="download-icon" src="/images/icons/download-logo.jpg" alt="" />
                    </a>
                }
            </div>

            <div class="comparison">
                <figure>
                    <span>Your Photo</span>
                    @if (uploadedPhotoDataUrl is null)
                    {
                        <img class="frame-placeholder" src="images/placeholders/your-photo-placeholder.png" alt="Your photo placeholder" />
                    }
                    else
                    {
                        <img class="uploaded-photo-preview" src="@uploadedPhotoDataUrl" alt="Uploaded Self Photo" />
                    }
                </figure>
                <div class="compare-arrow" aria-hidden="true">→</div>
                <figure aria-busy="@isGenerating">
                    <span>AI Preview - @(isShowingBackPreview ? "Back" : "Front")</span>
                    <img class="frame-placeholder @(DisplayedPreviewUrl is null ? null : "generated-preview")"
                         src="@(DisplayedPreviewUrl ?? "images/placeholders/ai-preview-placeholder.png")"
                         alt="@(DisplayedPreviewUrl is null ? "AI preview placeholder" : $"Generated AI gown {DisplayedPreviewLabel.ToLowerInvariant()} preview")" />
                    @if (isGenerating)
                    {
                        <div class="ai-frame-loading" role="status" aria-live="polite">
                            <div class="loading-ring" aria-hidden="true">
                                <span></span>
                            </div>
                            <strong>Generating AI Preview</strong>
                            <small>Tailoring your visualization...</small>
                        </div>
                    }
                </figure>
            </div>

            @if (latestPreviewUrl is not null)
            {
                <div class="preview-view-toggle" role="group" aria-label="Select AI preview view">
                    <button type="button"
                            class="@(!isShowingBackPreview ? "active" : null)"
                            aria-pressed="@(!isShowingBackPreview)"
                            @onclick="() => isShowingBackPreview = false">
                        Front View
                    </button>
                    <button type="button"
                            class="@(isShowingBackPreview ? "active" : null)"
                            aria-pressed="@isShowingBackPreview"
                            disabled="@(latestBackPreviewUrl is null)"
                            @onclick="() => isShowingBackPreview = true">
                        Back View
                    </button>
                </div>
            }

            <button type="button" class="generate-button" disabled="@isGenerating" @onclick="GeneratePreviewAsync">
                @(isGenerating ? "Generating AI Preview..." : "Generate AI Preview")
            </button>

            @if (!string.IsNullOrWhiteSpace(generationMessage))
            {
                <p class="generation-message @(generationSucceeded ? "success" : "error")" role="status">@generationMessage</p>
            }

            <div class="preview-note">
                <span>ⓘ</span>
                <p>The AI preview is generated for visualization purposes only. Final gown fit, fabric behavior, and appearance may vary.</p>
            </div>
        </section>

    </main>
</div>

@code {
    private string selectedDressTemplate = string.Empty;
    private string selectedBodiceDesign = string.Empty;
    private string selectedWaistShape = string.Empty;
    private string selectedFabricType = string.Empty;
    private string selectedFabricPattern = string.Empty;
    private string selectedColor = string.Empty;
    private string pickedColorHex = "#f1cfc3";
    private string selectedAccessories = string.Empty;
    private string selectedBackClosure = string.Empty;
    private string? uploadedPhotoDataUrl;
    private string? uploadedPhotoFileName;
    private string? photoUploadError;
    private string? latestPreviewUrl;
    private string? latestBackPreviewUrl;
    private Guid? latestPreviewRequestId;
    private string? generationMessage;
    private bool generationSucceeded;
    private IBrowserFile? selectedPhotoFile;
    private IReadOnlyList<DressStyleDto> catalogStyles = [];
    private IReadOnlyList<FabricDto> catalogFabrics = [];
    private readonly MeasurementDto measurementValues = new();
    private bool isGenerating;
    private bool isShowingBackPreview;
    private int photoInputKey;

    private const long MaxPhotoBytes = 10 * 1024 * 1024;

    private static readonly IReadOnlyList<string> DressTemplates =
    [
        "Textured Drop-Waist Tiered Gown",
        "Layered Tulle Princess Gown",
        "Structured Drop-Waist Pouf Gown",
        "Basque-Waist Metallic Ball Gown",
        "Ivory Brocade A-Line Gown with Side Bow",
        "Soft Satin Drop-Waist Gown"
    ];

    private static readonly IReadOnlyList<string> BodiceDesigns =
    [
        "Plain Fitted Bodice",
        "Princess Seam Bodice",
        "Textured Bodice",
        "Floral Applique Bodice",
        "Metallic Brocade Bodice",
        "Basque Waist Bodice",
        "Structured Shoulder Bodice",
        "Side-Draped Bodice"
    ];

    private static readonly IReadOnlyList<string> WaistShapes =
    [
        "Natural Waist",
        "Drop Waist",
        "Basque Waist",
        "Gathered Waist",
        "Built-In Waist Seam",
        "Side Bow Waist",
        "No Belt"
