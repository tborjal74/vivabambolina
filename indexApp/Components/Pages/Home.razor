    private static readonly IReadOnlyList<MaterialSampleOption> FabricTypes =
    [
        new("Satin", "satin"),
        new("Taffeta", "taffeta"),
        new("Mikado", "mikado"),
        new("Tulle", "tulle"),
        new("Layered Tulle", "layered-tulle"),
        new("Metallic Brocade", "brocade"),
        new("Jacquard", "jacquard"),
        new("Textured Jacquard", "textured-jacquard"),
        new("Embroidered Fabric", "embroidered"),
        new("Lace", "lace"),
        new("Organza", "organza")
    ];

    private static readonly IReadOnlyList<MaterialSampleOption> FabricPatterns =
    [
        new("Plain Smooth", "plain"),
        new("Metallic Shine", "metallic"),
        new("Raised Texture", "raised"),
        new("Floral Embroidery", "floral"),
        new("Gold Brocade", "gold"),
        new("Silver Brocade", "silver"),
        new("Jacquard Pattern", "jacquard"),
        new("Sequin Texture", "sequin"),
        new("Soft Sheer Layers", "sheer")
    ];

    private static readonly IReadOnlyList<IReadOnlyList<PaletteColor>> ColorPaletteRows =
    [
        [new("Deep Teal", "#123443"), new("Ocean Teal", "#07516d"), new("Marine Blue", "#06658d"), new("Royal Blue", "#0754b5"), new("Cobalt", "#123cca"), new("Indigo", "#2421c3"), new("Deep Violet", "#351da8")],
        [new("Pine", "#075b47"), new("Teal", "#087f76"), new("Lagoon", "#0799aa"), new("Cerulean", "#0796d0"), new("Azure", "#0874dc"), new("Sapphire", "#1752db"), new("Iris Blue", "#3831d7"), new("Violet", "#551bc1"), new("Plum", "#64179a")],
        [new("Forest Green", "#067027"), new("Emerald", "#00984e"), new("Jade", "#05b982"), new("Aqua", "#07cdd1"), new("Sky Blue", "#08bbeb"), new("Cornflower", "#2799f1"), new("Periwinkle", "#5283f0"), new("Lavender Blue", "#7861e7"), new("Orchid", "#982ed7"), new("Magenta", "#ac12aa"), new("Berry", "#94117d")],
        [new("Leaf Green", "#098015"), new("Kelly Green", "#00ad22"), new("Spring Green", "#00d357"), new("Mint Teal", "#02edb4"), new("Bright Cyan", "#16ebed"), new("Powder Blue", "#55ccf3"), new("Baby Blue", "#82b2f3"), new("Soft Lavender", "#ac8cea"), new("Lilac", "#cb61e6"), new("Fuchsia", "#e735d3"), new("Hot Pink", "#df14a7"), new("Raspberry", "#bd087b"), new("Wine Berry", "#95115b")],
        [new("Moss Green", "#176c13"), new("Grass Green", "#16ad0a"), new("Lime", "#42ea20"), new("Pistachio", "#7bf36c"), new("Seafoam", "#a7f8be"), new("Ice Mint", "#d4fbf3"), new("Pearl White", "#f5f7fa"), new("Pale Lavender", "#eddcff"), new("Blush Lilac", "#e7b7f9"), new("Mauve Pink", "#e881ed"), new("Pink Orchid", "#ec40d6"), new("Cerise", "#e916a2"), new("Deep Rose", "#be106e")],
        [new("Olive", "#46500b"), new("Olive Green", "#709712"), new("Chartreuse", "#9eda17"), new("Lemon Lime", "#cdf43b"), new("Butter Yellow", "#edfb79"), new("Vanilla", "#fcf5a6"), new("Ivory", "#fff1dd"), new("Blush", "#ffd8e3"), new("Soft Pink", "#ffb2cc"), new("Rose Pink", "#ff7ea8"), new("Watermelon", "#f84b7e"), new("Crimson Pink", "#e91b50"), new("Garnet", "#b70d39")],
        [new("Antique Gold", "#665111"), new("Old Gold", "#ac8410"), new("Goldenrod", "#dbb10b"), new("Sunflower", "#f2db14"), new("Yellow", "#ffed37"), new("Marigold", "#ffd15c"), new("Peach", "#ffad72"), new("Coral", "#fa7968"), new("Vermilion", "#ed493d"), new("Scarlet", "#dd221c"), new("Deep Red", "#aa1518")],
        [new("Walnut", "#624018"), new("Bronze", "#976212"), new("Burnt Amber", "#ca7a08"), new("Amber", "#ef9605"), new("Orange Gold", "#ffac03"), new("Tangerine", "#ff7300"), new("Orange Red", "#f34309"), new("True Red", "#df1809"), new("Oxblood", "#aa120d")],
        [new("Espresso", "#51301b"), new("Chestnut", "#774116"), new("Copper", "#a34b0f"), new("Burnt Orange", "#c85008"), new("Paprika", "#e24406"), new("Brick Red", "#d52107"), new("Mahogany", "#a3130b")]
    ];

    private static readonly IReadOnlyList<string> Accessories =
    [
        "None", "Side Bow", "Detachable Belt", "Floral Applique", "Beaded Detail"
    ];

    private static readonly IReadOnlyList<string> BackClosures =
    [
        "Hidden Zipper", "Corset Lace-Up", "Covered Buttons", "Side Zipper"
    ];

    private static readonly HashSet<string> AllowedPhotoExtensions = new(StringComparer.OrdinalIgnoreCase)
    {
        ".jpg",
        ".jpeg",
        ".png",
        ".webp"
    };

    private static readonly HashSet<string> AllowedPhotoContentTypes = new(StringComparer.OrdinalIgnoreCase)
    {
        "image/jpeg",
        "image/png",
        "image/webp"
    };

    private IReadOnlyList<FabricColorDto> AvailableColors => catalogFabrics
        .SelectMany(fabric => fabric.Colors)
        .DistinctBy(color => color.ColorName)
        .ToList();

    private PaletteColor? SelectedPaletteColor => ColorPaletteRows
        .SelectMany(row => row)
        .FirstOrDefault(color => color.HexCode == pickedColorHex && color.Name == selectedColor);

    private string? DisplayedPreviewUrl => isShowingBackPreview ? latestBackPreviewUrl : latestPreviewUrl;

    private string DisplayedPreviewLabel => isShowingBackPreview ? "Back" : "Front";

    private string GetPreviewDownloadUrl(Guid requestId)
    {
        return isShowingBackPreview
            ? $"/api/visualizer/request/{requestId}/download-preview?view=back"
            : $"/api/visualizer/request/{requestId}/download-preview";
    }

    private string HorsehairEdgeHemSelection
    {
        get => ToSelectionValue(measurementValues.HasHorsehairEdgeHem);
        set => measurementValues.HasHorsehairEdgeHem = ToNullableBoolean(value);
    }

    private string BuiltInPuffySelection
    {
        get => ToSelectionValue(measurementValues.HasBuiltInPuffy);
        set => measurementValues.HasBuiltInPuffy = ToNullableBoolean(value);
    }

    private static string ToSelectionValue(bool? value) => value switch
    {
        true => "yes",
        false => "no",
        null => string.Empty
    };

    private static bool? ToNullableBoolean(string value) => value switch
    {
        "yes" => true,
        "no" => false,
        _ => null
    };

    private static string GetEmail(System.Security.Claims.ClaimsPrincipal user)
    {
        return user.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value
            ?? user.Identity?.Name
            ?? "Admin";
    }

    protected override async Task OnInitializedAsync()
    {
        catalogStyles = await VisualizerService.GetStylesAsync();
        catalogFabrics = await VisualizerService.GetFabricsAsync();
    }

    private void SelectPaletteColor(PaletteColor color)
    {
        selectedColor = color.Name;
        pickedColorHex = color.HexCode;
    }

    private static (int Red, int Green, int Blue) ParseRgb(string hexCode)
    {
        var value = hexCode.TrimStart('#');
        return (
            Convert.ToInt32(value[0..2], 16),
            Convert.ToInt32(value[2..4], 16),
            Convert.ToInt32(value[4..6], 16));
    }

    private static int ColorDistance((int Red, int Green, int Blue) left, (int Red, int Green, int Blue) right)
    {
        var red = left.Red - right.Red;
        var green = left.Green - right.Green;
        var blue = left.Blue - right.Blue;
        return (red * red) + (green * green) + (blue * blue);
    }

    private async Task OnPhotoSelected(InputFileChangeEventArgs args)
    {
        var photo = args.File;
        var extension = Path.GetExtension(photo.Name);

        uploadedPhotoDataUrl = null;
        uploadedPhotoFileName = null;
        photoUploadError = null;
        selectedPhotoFile = null;

        if (!AllowedPhotoExtensions.Contains(extension) || !AllowedPhotoContentTypes.Contains(photo.ContentType))
        {
            photoUploadError = "Please upload a JPG, PNG, or WEBP image.";
            return;
        }

        if (photo.Size > MaxPhotoBytes)
        {
            photoUploadError = "Please upload an image that is 10MB or smaller.";
            return;
        }

        await using var stream = photo.OpenReadStream(MaxPhotoBytes);
        using var memory = new MemoryStream();
        await stream.CopyToAsync(memory);

        uploadedPhotoFileName = photo.Name;
        uploadedPhotoDataUrl = $"data:{photo.ContentType};base64,{Convert.ToBase64String(memory.ToArray())}";
        selectedPhotoFile = photo;
    }

    private void RemoveUploadedPhoto()
    {
        uploadedPhotoDataUrl = null;
        uploadedPhotoFileName = null;
        photoUploadError = null;
        selectedPhotoFile = null;
        photoInputKey++;
    }

    private async Task GeneratePreviewAsync()
    {
        generationMessage = null;
        generationSucceeded = false;

        if (selectedPhotoFile is null)
        {
            photoUploadError = "Upload a front-facing full-body photo before generating your AI preview.";
            generationMessage = "A photo is required so the AI preview can visualize the gown on you.";
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedDressTemplate)
            || string.IsNullOrWhiteSpace(measurementValues.NecklineShape)
            || string.IsNullOrWhiteSpace(measurementValues.SleeveShape)
            || string.IsNullOrWhiteSpace(selectedBodiceDesign)
            || string.IsNullOrWhiteSpace(selectedWaistShape)
            || string.IsNullOrWhiteSpace(measurementValues.SkirtShape)
            || string.IsNullOrWhiteSpace(selectedFabricType)
            || string.IsNullOrWhiteSpace(selectedFabricPattern)
            || string.IsNullOrWhiteSpace(selectedColor)
            || string.IsNullOrWhiteSpace(selectedAccessories)
            || string.IsNullOrWhiteSpace(selectedBackClosure))
        {
            generationMessage = "Complete all dress builder selections before generating your AI preview.";
            return;
        }

        var style = catalogStyles.FirstOrDefault();
        var selectedRgb = ParseRgb(pickedColorHex);
        var selectedCatalogColor = catalogFabrics
            .SelectMany(fabric => fabric.Colors.Select(color => (Fabric: fabric, Color: color)))
            .MinBy(item => ColorDistance(selectedRgb, ParseRgb(item.Color.HexCode)));
        var fabric = selectedCatalogColor.Fabric;
        var color = selectedCatalogColor.Color;

        if (style is null || fabric is null || color is null)
        {
            generationMessage = "The selected color is unavailable in the current catalog.";
            return;
        }

        isGenerating = true;
        try
        {
            var authenticationState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var userId = authenticationState.User.FindFirstValue(ClaimTypes.NameIdentifier);
            if (string.IsNullOrWhiteSpace(userId))
            {
                generationMessage = "Please sign in before generating a preview.";
                return;
            }

            var uploadedPhotoUrl = await FileStorageService.SaveUploadAsync(selectedPhotoFile, userId);

            var request = await VisualizerService.CreateRequestAsync(
                userId,
                new CreateVisualizerRequestDto
                {
                    DressStyleId = style.Id,
                    FabricId = fabric.Id,
                    FabricColorId = color.Id,
                    Measurement = measurementValues,
                    DesignSelection = new DesignSelectionDto
                    {
                        DressTemplate = selectedDressTemplate,
                        BodiceDesign = selectedBodiceDesign,
                        WaistShape = selectedWaistShape,
                        FabricType = selectedFabricType,
                        FabricPattern = selectedFabricPattern,
                        ColorName = selectedColor,
                        ColorHexCode = pickedColorHex,
                        Accessories = selectedAccessories,
                        BackClosure = selectedBackClosure
                    }
                },
                uploadedPhotoUrl);

            var result = await VisualizerService.GenerateAiPreviewAsync(
                userId,
                new GenerateAiPreviewRequest(request.Id, "medium", "1024x1536"));

            if (string.IsNullOrWhiteSpace(result.ImageUrl))
            {
                generationMessage = result.ErrorMessage ?? "AI preview generation failed. Please try again.";
                return;
            }

            latestPreviewUrl = result.ImageUrl;
            latestBackPreviewUrl = result.BackImageUrl;
            latestPreviewRequestId = result.VisualizerRequestId;
            isShowingBackPreview = false;
            generationMessage = "AI preview generated successfully.";
            generationSucceeded = true;
        }
        catch (Exception ex)
        {
            generationMessage = $"AI preview generation failed: {ex.Message}";
        }
        finally
        {
            isGenerating = false;
        }
    }

